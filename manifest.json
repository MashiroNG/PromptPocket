{
  "manifest_version": 3,
  "name": "PromptPocket 提示词口袋",
  "version": "1.1.6",
  "version_name": "1.1.6",
  "description": "为 ChatGPT 网页版优化的本地提示词管理插件，支持收藏、搜索、置顶、快捷输入和安全导入备份。",
  "permissions": ["storage", "contextMenus", "clipboardWrite", "sidePanel", "activeTab", "scripting"],
  "host_permissions": ["https://chatgpt.com/*", "https://chat.openai.com/*", "https://gemini.google.com/*"],
  "action": {
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*", "https://gemini.google.com/*"],
      "js": ["sidepanel-logic.js", "injection-routing.js", "content.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
